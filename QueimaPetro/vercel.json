{
  "builds": [
    {
      "src": "QueimaPetro/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.12",
        "build": "python manage.py collectstatic --noinput"
      }
    },
    {
      "src": "static/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "QueimaPetro/wsgi.py"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.12"
  }
}